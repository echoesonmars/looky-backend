PORT=3001
NODE_ENV=development

# Supabase Postgres (Dashboard → Settings → Database → URI)
# If the password ends with @, encode it as %40 (e.g. ...secret%40@db.xxx.supabase.co)
DATABASE_URL=

# Optional: URL of the FastAPI service (no trailing slash), e.g. http://localhost:8000
PYTHON_SERVICE_URL=http://localhost:8000
